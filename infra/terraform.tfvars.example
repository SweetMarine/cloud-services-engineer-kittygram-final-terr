# Yandex Cloud settings
cloud_id  = "your-cloud-id"
folder_id = "your-folder-id"

# VM settings
zone          = "ru-central1-a"
image_family  = "ubuntu-2404-lts-oslogin"
platform_id   = "standard-v1"
cores         = 2
memory        = 2
core_fraction = 20
disk_type     = "network-hdd"
disk_size     = 20
nat           = true

# SSH public key content (not file path)
ssh_key = "ssh-ed25519 AAAA... user@host"

# Service account key file path created in CI job
sa_key_file = "authorized_key.json"